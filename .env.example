# ── SteelCraft Frontend Environment Variables ────────────────────
#
# Copy this file to .env (same folder) and fill in your real values.
# Never commit .env to version control.

# Supabase project settings → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PASSWORD_KEY=

# Name of the AI Builder edge function (only change if you renamed it)
VITE_SUPABASE_AI_FUNCTION=ai-design

# ── Gemini API key does NOT go here ───────────────────────────────
# The AI Builder runs server-side in the `ai-design` Supabase Edge
# Function, not in the browser. Any VITE_ var in this file gets
# bundled straight into the client JS, so a real key here would be
# readable by anyone who opens devtools. Set it as a Supabase secret
# instead (run once per project, never committed):
#
#   supabase secrets set GEMINI_API_KEY=your-gemini-key
#
# Get a key at https://aistudio.google.com/apikey
